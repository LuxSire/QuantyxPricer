{
  "model": "montecarlo",
  "description": "Monte Carlo bond pricer using the Hull-White one-factor short-rate model. Supports the same coupon structures as hullwhite. Suited for callable bonds where path-dependency matters.",
  "required_fields": [
    { "name": "instrument_id",           "type": "string", "description": "ISIN or internal identifier" },
    { "name": "description",             "type": "string", "description": "Human-readable name" },
    { "name": "evaluation_date",         "type": "string", "description": "Pricing date (DD-MM-YYYY or YYYY-MM-DD)" },
    { "name": "issue_date",              "type": "string", "description": "Issue date (DD-MM-YYYY or YYYY-MM-DD)" },
    { "name": "maturity_date",           "type": "string", "description": "Maturity date (DD-MM-YYYY or YYYY-MM-DD)" },
    { "name": "coupon_frequency",        "type": "string", "description": "Coupon payment frequency", "enum": ["Annual", "Semiannual", "Quarterly", "Monthly"] },
    { "name": "accrual_day_count",       "type": "string", "description": "Day count convention", "enum": ["Actual365Fixed", "Actual360", "ACT/ACT (ICMA)", "30/360"] },
    { "name": "calendar",                "type": "string", "description": "Holiday calendar", "enum": ["TARGET", "UnitedStates"] },
    { "name": "business_day_convention", "type": "string", "description": "Business day adjustment", "enum": ["ModifiedFollowing", "Following", "Unadjusted"] },
    { "name": "date_generation",         "type": "string", "description": "Schedule generation direction", "enum": ["Backward", "Forward"] },
    { "name": "par",                     "type": "float",  "description": "Face value (e.g. 100)" },
    { "name": "credit_spread_bp",        "type": "float",  "description": "Z-spread over the discount curve in basis points" },
    { "name": "coupon_structure",        "type": "string", "description": "Coupon type (see hullwhite for floating/CMS variants)", "enum": ["fixed", "floating", "fixed_to_float", "cms_resettable"] },
    { "name": "fixed_coupon_rate",       "type": "float",  "description": "Annual coupon rate. Required when coupon_structure is 'fixed' or 'fixed_to_float'" }
  ],
  "optional_fields": [
    { "name": "hw_a",             "type": "float",  "default": 0.03,        "description": "Hull-White mean reversion speed" },
    { "name": "hw_sigma",         "type": "float",  "default": 0.01,        "description": "Hull-White short-rate volatility" },
    { "name": "mc_time_steps",    "type": "int",    "default": 360,         "description": "Number of time steps per simulated path" },
    { "name": "mc_num_paths",     "type": "int",    "default": 5000,        "description": "Number of Monte Carlo paths" },
    { "name": "mc_seed",          "type": "int",    "default": 42,          "description": "Random seed for reproducibility" },
    { "name": "issuer_spread_bp", "type": "float",  "default": null,        "description": "Z-spread override; falls back to credit_spread_bp if absent" },
    { "name": "call_dates",       "type": "list",   "default": [],          "description": "List of callable dates (DD-MM-YYYY)" },
    { "name": "call_price",       "type": "float",  "default": null,        "description": "Call price as % of par (default = par)" },
    { "name": "callable_type",    "type": "string", "default": "bermudan",  "description": "Callability type", "enum": ["bermudan", "american"] }
  ]
}
